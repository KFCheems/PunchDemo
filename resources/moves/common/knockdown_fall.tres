[gd_resource type="Resource" load_steps=8 format=3]

[ext_resource type="Script" path="res://scripts/data/schema/move_data.gd" id="1_move"]
[ext_resource type="Script" path="res://scripts/data/schema/frame_data.gd" id="2_frame"]
[ext_resource type="Script" path="res://scripts/data/schema/hurtbox_data.gd" id="3_hurtbox"]

[sub_resource type="Resource" id="Hurtbox_default"]
script = ExtResource("3_hurtbox")
local_rect = Rect2(-18.0, -56.0, 36.0, 56.0)

[sub_resource type="Resource" id="Hurtbox_grounded"]
script = ExtResource("3_hurtbox")
local_rect = Rect2(-18.0, -1.0, 36.0, 10.0)

[sub_resource type="Resource" id="Frame_fall_a"]
script = ExtResource("2_frame")
display_id = &"knockdown_0"
duration_ticks = 6
interruptible = false
cancelable = false
hurtboxes = [SubResource("Hurtbox_default")]

[sub_resource type="Resource" id="Frame_fall_b"]
script = ExtResource("2_frame")
display_id = &"knockdown_1"
duration_ticks = 6
interruptible = false
cancelable = false
hurtboxes = [SubResource("Hurtbox_default")]

[sub_resource type="Resource" id="Frame_fall_c"]
script = ExtResource("2_frame")
display_id = &"knockdown_2"
duration_ticks = 6
interruptible = false
cancelable = false
hurtboxes = [SubResource("Hurtbox_default")]

[sub_resource type="Resource" id="Frame_fall_d"]
script = ExtResource("2_frame")
display_id = &"knockdown_3"
duration_ticks = 18
interruptible = false
cancelable = false
hurtboxes = [SubResource("Hurtbox_grounded")]

[resource]
script = ExtResource("1_move")
move_name = &"knockdown_fall"
state_tag = 2
loop = false
return_to = &"knockdown_downed"
frames = [SubResource("Frame_fall_a"), SubResource("Frame_fall_b"), SubResource("Frame_fall_c"), SubResource("Frame_fall_d")]
